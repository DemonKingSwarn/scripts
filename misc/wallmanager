#!/bin/sh

new="$(rofi -show file-browser-extended -file-browser-dir ~/media/pix/wall -file-browser-cmd basename -file-browser-hide-parent -show-icons -config ~/.config/rofi/wallpaper.rasi)"
wall="$HOME/.cache/wall.jxl"

if [ -z "$new" ]; then
  notify-send "wallmanager" "nothing selected..."
  exit 1
else
  new="$HOME/media/pix/wall/$new"
  awww clear
  cp "$new" "$wall"
  awww img $wall --transition-type center --transition-fps 60
fi

